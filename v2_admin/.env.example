# ── 侨联地产频道发布系统 · 环境变量配置 ──────────────────────────────
# 复制此文件为 .env，填写真实值

# 发布 Bot Token
# 如果和用户 Bot 是同一个 token，填 BOT_TOKEN 即可
# 如需区分，使用 PUBLISHER_BOT_TOKEN（优先级更高）
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# 专用发布 Bot（可选，留空则用 BOT_TOKEN）
# PUBLISHER_BOT_TOKEN=

# 目标频道 ID（带 -100 前缀）
CHANNEL_ID=-1001234567890

# 用户 Bot 用户名（不带 @，用于生成 deep-link 按钮）
# 若无用户 Bot，留空，按钮将退回频道链接
USER_BOT_USERNAME=qiaolian_bot

# SQLite 数据库路径（绝对路径或相对路径）
DB_PATH=/home/ubuntu/qiaolian/qiaolian.db

# 图片上传目录（绝对路径）
UPLOAD_DIR=/home/ubuntu/qiaolian/channel_publisher/uploads

# 后台监听端口
ADMIN_PORT=5005

# Flask session secret（随机字符串）
FLASK_SECRET=change-me-to-a-random-string

# =============================================================================
# 侨联整站唯一环境文件模板 —— 复制为 /opt/qiaolian_dual_bots/.env 后填值
# v2 / v2_admin / 根目录脚本均通过符号链接或 load_dotenv(项目根/.env) 读这一份
# =============================================================================

# --- 唯一管理员/发布 Bot（@meihua666）：v2 向导 + /pending /send /slots 等已合并进同一进程 ---
PUBLISHER_BOT_TOKEN=
PUBLISHER_BOT_USERNAME=meihua666bot
CHANNEL_ID=
CHANNEL_URL=

# --- 客户承接 Bot（频道按钮深链指向此号，与管理员号分离）---
USER_BOT_TOKEN=
USER_BOT_USERNAME=

# --- 仅本地调试独立 autopilot 进程时填写；生产勿开 qiaolian-autopilot-publish.service ---
# AUTOPILOT_BOT_TOKEN=

ADMIN_IDS=
DB_PATH=data/qiaolian_dual_bot.db
SQLITE_PATH=data/qiaolian_dual_bot.db

OPENROUTER_API_KEY=
TG_API_ID=
TG_API_HASH=
# TELETHON_SESSION_PATH=/opt/qiaolian_dual_bots/v2/你的session基名

BRAND_NAME=侨联地产
ADVISOR_TG=@pengqingw
AUTOPILOT_TIMEZONE=Asia/Phnom_Penh
PUBLISH_SLOTS=09:00,12:00,15:00,20:00
DEFAULT_CONTACT_HANDLE=@qiaolian_advisor

# 频道用户名（不含 @），用于生成评论区链接
# https://t.me/{CHANNEL_USERNAME}/{channel_message_id}?comment=1
# 若留空，会自动从 CHANNEL_URL 推导；推导失败时降级使用 DISCUSSION_GROUP_LINK
CHANNEL_USERNAME=

# 讨论群直链（CHANNEL_USERNAME 缺失时降级使用）
DISCUSSION_GROUP_LINK=

# 对外展示的客服用户名（不含 @）
SUPPORT_USERNAME=

# --- Admin Web ---
ADMIN_PORT=5005
FLASK_SECRET=change-me-in-production
UPLOAD_DIR=/opt/qiaolian_dual_bots/v2_admin/uploads
